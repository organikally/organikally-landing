# organikally-landing — environment template (STORE_CONTRACT §15.1)
# Copy to `.env.local` and fill in. SITE_URL is NOT an env var — it is a constant in
# src/lib/site.ts (single source of truth for canonical/OG/sitemap URLs).

# Server-only base for SSR/ISR storefront fetches (never exposed to the browser).
API_BASE=https://api.organikaly.com/api/v1

# Public base for client-side cart / checkout / customer-auth calls.
NEXT_PUBLIC_API_BASE=https://api.organikaly.com/api/v1

# Optional — Razorpay public key id. If unset, the client uses the key_id the backend
# returns from the checkout response / GET /store/config.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Shared secret for POST /api/revalidate — must match the backend's REVALIDATE_SECRET.
REVALIDATE_SECRET=
